"""Main MCP server module.

AI-powered song generation server using Tencent AI Lab's LeVo model.
Supports lyrics, style control, and stem separation.
"""

import logging
from typing import List

from fastmcp import FastMCP

from .logic import SongGenerationLogic

# Setup logging
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger("songgeneration-mcp")

# JSON Schema for Song Generation
SONG_REQUEST_SCHEMA = {
    "title": "SongRequest",
    "type": "object",
    "properties": {
        "title": {"type": "string", "description": "Title of the song"},
        "lyrics": {"type": "string", "description": "Complete lyrics"},
        "genre": {"type": "string", "description": "Musical genre"},
        "emotion": {"type": "string", "description": "Musical emotion/mood"},
        "bpm": {"type": "integer", "description": "Beats per minute"},
        "voice": {"type": "string", "enum": ["Male", "Female"], "default": "Female"},
        "output_mode": {"type": "string", "enum": ["mixed", "separate"], "default": "separate"},
    },
    "required": ["lyrics"],
}

app = FastMCP(
    "songgeneration-mcp",
    title="SongGeneration SOTA MCP",
    description="Advanced AI song generation utilizing Tencent LeVo via SongGeneration-Studio.",
)
logic = SongGenerationLogic()


@app.resource("api://song-request-schema")
def get_song_schema() -> str:
    """Get the JSON schema for song generation requests."""
    import json

    return json.dumps(SONG_REQUEST_SCHEMA, indent=2)


@app.resource("system://gpu-status")
async def get_gpu_status_resource() -> str:
    """Get real-time GPU and VRAM status information."""
    status_data = await logic.get_status()
    return f"""# GPU Resource Status
| Metric | Value |
| :--- | :--- |
| **VRAM Total** | {status_data["vram_total"]} MB |
| **VRAM Used** | {status_data["vram_used"]} MB |
| **Active Tasks** | {status_data["active_generations"]} |
| **Model Loaded** | {status_data.get("model_loaded", "None")} |
| **Server Status** | {"✅ Running" if status_data.get("server_running") else "❌ Offline"} |
"""


@app.prompt("generate-song")
def prompt_generate_song(topic: str = "Life in Vienna", genre: str = "Pop") -> str:
    """Template for generating a new song with a specific topic and genre."""
    return f"""Generate a new song about '{topic}' in the style of '{genre}'.
Please provide:
1. A catchy title.
2. Structured lyrics (Verse, Chorus, Bridge).
3. BPM and Mood recommendations.

Once ready, use the `generate_song` tool to start production."""


@app.prompt("lyric-assistant")
def prompt_lyric_assistant(lyrics: str) -> str:
    """Analyzes and refines lyrics for optimal generation with the LeVo model."""
    return f"""Optimize the following lyrics for an AI song generation model:

{lyrics}

Focus on:
- Rhyme scheme and rhythm consistency.
- Phrasing that fits typical song structures (Verse-Chorus).
- Emotional resonance aligned with the mood.
"""


@app.tool()
async def help(level: str = "basic", topic: str | None = None) -> str:
    """Get help information about this MCP server.

    Args:
        level: Detail level - "basic", "intermediate", or "advanced"
        topic: Optional topic to focus on

    Returns:
        Help text for the server
    """
    if level == "basic":
        return """# songgeneration-mcp Help

## Overview
AI-powered song generation server using Tencent AI Lab's LeVo model.
Supports lyrics, style control, and stem separation.

## Available Tools
- list_models: Show available generation models
- generate_song: Create a new song with lyrics and style
- get_status: Monitor VRAM and active generation tasks
- cancel_generation: Stop an active generation task
- unload_models: Free GPU memory
- status: Get server diagnostic information
- help: Show this help message
"""
    elif level == "intermediate":
        return """# songgeneration-mcp - Intermediate Help

## generation Workflow
1. Use `list_models` to see what models are loaded.
2. Call `generate_song` with your lyrics and style parameters.
3. Monitor progress with `get_status`.
4. If you're done, use `unload_models` to save VRAM for other processes.

## Examples
- generate_song(lyrics="Verse 1...", genre="Pop", mood="Energetic")
- get_status()
"""
    else:
        return """# songgeneration-mcp - Advanced Help

## Under the Hood
This server bridges to the SongGeneration-Studio backend.
It uses standard SOTA patterns for VRAM management and task queuing.
"""


@app.tool()
async def list_models() -> List[str]:
    """List all available high-quality song generation models from the backend.

    Retrieves the list of model identifiers currently supported by the
    SongGeneration-Studio model server.

    Returns:
        List of model ID strings (e.g., ["levo-v1", "studio-v2"]).
    """
    return await logic.list_models()


@app.tool()
async def generate_song(
    lyrics: str,
    genre: str = "Pop",
    mood: str = "Happy",
    tempo: int = 120,
    voice: str = "Female",
    structure: List[str] = ["Verse", "Chorus"],
    separate_stems: bool = True,
) -> str:
    """Generate a high-quality song with vocals and professional backing tracks.

    This tool triggers the full generation pipeline:
    1. Loads the required LeVo model into GPU VRAM.
    2. Processes lyrics for vocal synthesis.
    3. Generates instrumental backing tracks.
    4. Performs mixing and optional stem separation.

    Args:
        lyrics: Complete lyrics for the song (Markdown formatted).
        genre: Musical genre (e.g., Rock, Pop, Electronic, Jazz).
        mood: Overall vibe or emotional state (e.g., Energetic, Melancholic).
        tempo: BPM (Beats Per Minute), usually between 60 and 180.
        voice: Vocal type preference: "Male" or "Female".
        structure: The desired order of song sections.
        separate_stems: If True, returns separate tracks for vocals and instruments.

    Returns:
        A status message containing the Task ID for monitoring.
    """
    request = {
        "lyrics": lyrics,
        "genre": genre,
        "mood": mood,
        "tempo": tempo,
        "voice": voice,
        "structure": structure,
        "separate_stems": separate_stems,
    }
    return await logic.generate_song(request)


@app.tool()
async def get_status() -> str:
    """Get detailed GPU VRAM metrics and current generation service state.

    Provides critical telemetry for resource management including memory
    usage and task saturation.

    Returns:
        Formatted Markdown report of the system status.
    """
    status_data = await logic.get_status()
    vram_percent = (
        (status_data["vram_used"] / status_data["vram_total"] * 100)
        if status_data["vram_total"] > 0
        else 0
    )

    return f"""# SongGeneration System Status
> [!NOTE]
> Backend monitoring active on {logic.base_url}

### GPU Telemetry
- **VRAM Total:** {status_data["vram_total"]} MB
- **VRAM Used:** {status_data["vram_used"]} MB ({vram_percent:.1f}%)
- **Active Tasks:** {status_data["active_generations"]}
- **Queued Tasks:** {status_data["queued_tasks"]}

### Model Server
- **Status:** {"✅ Online" if status_data.get("server_running") else "❌ Offline"}
- **Active Model:** `{status_data.get("model_loaded") or "None"}`
"""


@app.tool()
async def cancel_generation(task_id: str) -> str:
    """Immediately stop an active or pending song generation task.

    Args:
        task_id: The unique identifier for the task to be cancelled.

    Returns:
        Confirmation message or error if the task could not be stopped.
    """
    success = await logic.cancel_generation(task_id)
    if success:
        return f"### ✅ Task Cancelled\nTask `{task_id}` has been successfully terminated."
    return f"### ❌ Cancellation Failed\nTask `{task_id}` was not found or has already finished."


@app.tool()
async def unload_models() -> str:
    """Unload all active AI models from GPU VRAM to free resources.

    Use this tool when no further generations are planned to release
    high-performance hardware resources for other applications.

    Returns:
        Status message confirming the resource release.
    """
    success = await logic.unload_models()
    if success:
        return "> [!TIP]\n> Models successfully purged from VRAM. GPU is now free."
    return "> [!WARNING]\n> Failed to unload models. Backend may be busy or unreachable."


@app.tool()
async def diagnostics() -> str:
    """Run comprehensive system diagnostics for the MCP server.

    Returns:
        Markdown diagnostic report.
    """
    return """# songgeneration-mcp Diagnostics
- **Status:** Operational
- **Architecture:** FastMCP SOTA
- **Backend:** SongGeneration-Studio REST
- **Local Time:** 2026-01-02
"""


if __name__ == "__main__":
    app.run()
